{
  "version": 1,
  "id": "meta-reels",
  "name": "Instagram & Facebook Reels",
  "description": "Portrait video tuned for Reels — crisp at phone size and quick to upload.",
  "platform": "Meta",
  "favouredAspect": "9:16",
  "allowedAspects": ["9:16", "4:5", "1:1"],
  "maxFileSizeMB": 250,
  "video": {
    "codec": "libx264",
    "scaleShortEdgeTo": 1080,
    "fps": 30,
    "rate": { "targetKbps": 12000, "maxKbps": 16000, "bufsizeKbps": 24000 },
    "profile": "high",
    "level": "4.2",
    "gopSeconds": 2,
    "bFrames": 2,
    "faststart": true,
    "colourTags": true
  },
  "audio": { "codec": { "aacKbps": 128 }, "loudnessTarget": -14 }
}
