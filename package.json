{
  "name": "kookaburra-cut",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "license": "MIT OR Apache-2.0",
  "packageManager": "pnpm@11.0.4",
  "description": "Local, deterministic animated-video studio for macOS (Apple Silicon). Tauri 2 + React 19 + react-three-fiber, exporting via a bundled ffmpeg sidecar.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/michael-palmes/kookaburra-cut.git"
  },
  "bugs": {
    "url": "https://github.com/michael-palmes/kookaburra-cut/issues"
  },
  "homepage": "https://kookaburracut.com/",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "format": "biome format --write .",
    "setup:ffmpeg": "bash scripts/setup-ffmpeg.sh",
    "setup:ffmpeg:release": "bash scripts/build-ffmpeg-sidecar.sh",
    "setup:icon": "bash scripts/make-icons.sh",
    "clean:shell": "cargo clean --manifest-path src-tauri/Cargo.toml -p kookaburra-cut",
    "assets:hdri": "zsh scripts/prepare-hdri.sh",
    "assets:placeholder-phone": "BLENDER=${BLENDER:-/Applications/Blender.app/Contents/MacOS/Blender}; $BLENDER -b -P scripts/make-placeholder-phone.py -- src/assets/models/placeholder-phone.glb",
    "assets:phone": "bash scripts/prepare-device-model.sh iphone-15-pro",
    "assets:iphone-17-pro": "bash scripts/prepare-device-model.sh iphone-17-pro",
    "assets:macbook-pro-16": "bash scripts/prepare-device-model.sh macbook-pro-16",
    "assets:devices": "bash scripts/prepare-device-model.sh iphone-15-pro && bash scripts/prepare-device-model.sh iphone-17-pro && bash scripts/prepare-device-model.sh macbook-pro-16",
    "assets:device-previews": "bash scripts/render-device-previews.sh",
    "assets:text3d-font": "node scripts/prepare-text3d-font.mjs",
    "assets:emoji-fonts": "node scripts/prepare-emoji-fonts.mjs",
    "kookaburra:run": "bash scripts/kookaburra-run.sh",
    "package:dmg": "bash scripts/make-dmg.sh",
    "package:signed": "bash scripts/sign-and-notarize.sh",
    "release": "bash scripts/release.sh",
    "tauri": "tauri"
  },
  "engines": {
    "node": ">=20.19"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@react-three/postprocessing": "^3.0.4",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@xterm/addon-clipboard": "^0.2.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "animejs": "^4.4.1",
    "d3-ease": "^3.0.1",
    "d3-interpolate": "^3.0.1",
    "esbuild-wasm": "0.28.1",
    "postprocessing": "6.39.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "three": "^0.184.0",
    "troika-three-text": "^0.52.4",
    "troika-three-utils": "0.52.4",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@fontsource/noto-sans-math": "^5.2.9",
    "@fontsource/noto-sans-symbols": "^5.2.11",
    "@fontsource/noto-sans-symbols-2": "^5.2.8",
    "@tauri-apps/cli": "^2.11.3",
    "@types/d3-ease": "^3.0.2",
    "@types/d3-interpolate": "^3.0.4",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-react": "^6.0.2",
    "opentype.js": "^2.0.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  }
}
